# Refinery app
# Used by direct Python/uvicorn runs.
PORT=5055
REFERENCE_ROOT=./refs
MAX_TTS_CACHE_ITEMS=256

# Upstream Fish Audio / Fish-Speech TTS
# For direct Python/uvicorn runs, point this at either a local Fish-Speech
# server or the hosted Fish Audio API.
FISH_TTS_URL=http://127.0.0.1:8080/v1/tts
FISH_API_KEY=
FISH_MODEL=s2-pro
# 0 disables the generation/read timeout. Keep connect finite so an offline
# local Fish-Speech fails quickly.
FISH_TTS_TIMEOUT_SECONDS=0
FISH_CONNECT_TIMEOUT_SECONDS=10

# Docker Compose: Refinery container
REFINERY_PORT=5055

# Docker Compose: optional Fish-Speech service
FISH_SPEECH_IMAGE=fishaudio/fish-speech:latest
FISH_SPEECH_PORT=8080
FISH_SPEECH_CHECKPOINT=s2-pro
FISH_SPEECH_CHECKPOINTS=./fish-checkpoints
FISH_SPEECH_REFERENCES=./fish-references

# Native macOS Fish-Speech install/start scripts
# These keep Fish-Speech project-local and avoid clobbering other installs.
REFINERY_FISH_NATIVE_ROOT=.local/fish-speech
FISH_SPEECH_REPO_URL=https://github.com/fishaudio/fish-speech.git
FISH_SPEECH_REPO_REF=main
FISH_SPEECH_MODEL_REPO=fishaudio/s2-pro
FISH_SPEECH_PYTHON_VERSION=3.12
FISH_SPEECH_UV_EXTRA=
FISH_SPEECH_DEVICE=mps
FISH_SPEECH_HALF=1
FISH_SPEECH_HOST=127.0.0.1
FISH_SPEECH_API_PORT=8080
FISH_SPEECH_API_KEY=

# Passed through to Fish-Speech's API server by both Docker and native launchers.
FISH_SPEECH_EXTRA_ARGS=
